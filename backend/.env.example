DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=your_jwt_secret_here
# Optional. Default 24h. Longer lifetime = larger window if a token leaks; refresh tokens would improve UX.
# JWT_EXPIRES_IN=24h
PORT=3000
# Comma-separated browser origins allowed to call the API (CORS). Defaults to localhost:5173 if unset.
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Set to 1 behind a reverse proxy so rate limiting uses the real client IP (X-Forwarded-For).
# TRUST_PROXY=1
